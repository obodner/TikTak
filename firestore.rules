rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // The frontend fetches tenant configuration via the secure Cloud Function /api/getTenantInfo
    // Direct client-side read access to root configuration is restricted for security.
    
    match /tenants/{tenantId} {
      // Admins can read their own tenant document if their UID is in the adminUids array
      allow read, update: if request.auth != null && request.auth.uid in resource.data.adminUids;
      
      // Cascading rules for the tickets subcollection
      match /tickets/{ticketId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.adminUids;
      }

      // New: Admin Users subcollection
      match /adminUsers/{adminUserId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.adminUids;
      }
    }
  }
}