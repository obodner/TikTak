rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper: Check if user has Super Admin role via Custom Claims
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'super';
    }

    // Helper: Check if user is a tenant admin
    function isTenantAdmin(tenantId) {
      return request.auth != null && (
        isSuperAdmin() || 
        request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.adminUids
      );
    }
    
    match /tenants/{tenantId} {
      // For get/list on the tenant itself, resource.data is more efficient and supports queries
      allow read: if request.auth != null && (
        isSuperAdmin() || 
        request.auth.uid in resource.data.adminUids
      );
      allow update: if isTenantAdmin(tenantId);
      
      match /{allSubcollections=**} {
        allow read, write: if isTenantAdmin(tenantId);
      }
    }

    // Centralized Audit Logs (Root Collection)
    match /audit_logs/{logId} {
      // Anyone logged in can create a log (from the app logic)
      allow create: if request.auth != null; 
      
      // Only Super Admins can read the global audit feed
      allow read: if isSuperAdmin();
      
      allow update, delete: if false; // Immutable
    }

    // Global Holidays Collection
    match /holidays/{countryCode} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // Leads Collection for SaaS Landing Page
    match /leads/{leadId} {
      // Public is allowed to create leads (register for pilot)
      allow create: if true;
      
      // Only Super Admins can view, modify, or remove lead submissions
      allow read, update, delete: if isSuperAdmin();
    }

    // Sessions Collection (WhatsApp Bot state) - Backend Admin SDK only
    match /sessions/{phoneNumber} {
      allow read, write: if false;
    }
  }
}